{
    "interface_version": 2,
    "name": "MaaResonance",
    "label": "MaaResonance",
    "title": "MaaResonance",
    "description": "基于 MaaFramework 的 Resonance 自动化辅助项目。",
    "contact": "Issues: https://github.com/DaiMao204/MaaResonance/issues",
    "license": "AGPL-3.0-only",
    "welcome": "当前处于公开测试阶段，主要测试功能稳定性。遇到异常请附带 MXU 日志、任务配置和出错界面截图反馈。",
    "github": "https://github.com/DaiMao204/MaaResonance",
    "version": "v1.2.0-beta.2",
    "mirrorchyan_rid": "MaaResonance",
    "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "ADB",
            "label": "安卓模拟器",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "official",
            "label": "官服",
            "path": [
                "./resource/base"
            ],
            "controller": [
                "ADB"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "identifier": "maa_resonance_agent",
        "child_args": [
            "-u",
            "../agent/main.py"
        ]
    },
    "group": [
        {
            "name": "account",
            "label": "账号配置"
        },
        {
            "name": "trade",
            "label": "跑商"
        },
        {
            "name": "system",
            "label": "系统"
        }
    ],
    "task": [],
    "option": {},
    "preset": [
        {
            "name": "auto-business",
            "label": "自动跑商",
            "description": "启动游戏后自动规划并执行双城跑商。",
            "task": [
                {
                    "name": "LaunchGame",
                    "enabled": true
                },
                {
                    "name": "AutoTwoCityBusiness",
                    "enabled": true,
                    "option": {
                        "AutoTwoCityPriorityCity1": "none",
                        "AutoTwoCityPriorityCity2": "none",
                        "AutoTwoCityExcludeCities": [],
                        "AutoTwoCityPlannerParams": {
                            "max_restock": "6"
                        },
                        "AutoTwoCityWulinyuanPriority": "total",
                        "ManualTwoCityRunMode": "until_fatigue_exhausted",
                        "ManualTwoCityAccountProfileReadMode": "smart",
                        "ManualTwoCityAutoImpactDrill": "Yes",
                        "ManualTwoCityAutoSpeedProjectile": "Yes",
                        "ManualTwoCityAutoDrink": "Yes",
                        "ManualTwoCityAutoBento": "Yes",
                        "ManualTwoCityUseMedicine": "No"
                    }
                }
            ]
        },
        {
            "name": "manual-business",
            "label": "手动跑商",
            "description": "按指定起点和目标城市执行双城跑商。",
            "task": [
                {
                    "name": "LaunchGame",
                    "enabled": true
                },
                {
                    "name": "ManualTwoCityBusiness",
                    "enabled": true,
                    "option": {
                        "ManualTwoCityStartCity": "修格里城",
                        "ManualTwoCityStartParams": {
                            "start_book": "2",
                            "start_bargain_percent": "20",
                            "start_raise_percent": "20"
                        },
                        "ManualTwoCityTargetCity": "7号自由港",
                        "ManualTwoCityTargetParams": {
                            "target_book": "2",
                            "target_bargain_percent": "20",
                            "target_raise_percent": "20"
                        },
                        "ManualTwoCityRunMode": "until_fatigue_exhausted",
                        "ManualTwoCityAccountProfileReadMode": "smart",
                        "ManualTwoCityAutoImpactDrill": "Yes",
                        "ManualTwoCityAutoSpeedProjectile": "Yes",
                        "ManualTwoCityAutoDrink": "Yes",
                        "ManualTwoCityAutoBento": "Yes",
                        "ManualTwoCityUseMedicine": "No"
                    }
                }
            ]
        }
    ],
    "import": [
        "resource/tasks/ManualTwoCityBusiness.json",
        "resource/tasks/AutoTwoCityBusiness.json",
        "resource/tasks/LaunchGame.json"
    ]
}
