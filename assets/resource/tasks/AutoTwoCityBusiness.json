{
    "task": [
        {
            "name": "AutoTwoCityBusiness",
            "label": "自动双城跑商",
            "entry": "RunAutoTwoCityBusiness",
            "group": [
                "trade"
            ],
            "resource": [
                "official"
            ],
            "controller": [
                "ADB"
            ],
            "pipeline_override": {
                "StateRecoveryComplete": {
                    "next": "ManualTwoCityBusinessAccountProfileWarmupStartFromMainMap"
                },
                "StateRecoveryFailed": {
                    "next": "ManualTwoCityBusinessTradeEntryFailed"
                },
                "CityTradeOutletOpenDone": {
                    "next": "ManualTwoCityBusinessTradeOutletOpenDoneDispatch"
                },
                "CityTradeOutletOpenFailed": {
                    "next": "ManualTwoCityBusinessTradeOutletOpenFailedDispatch"
                },
                "AccountProfileReadStart": {
                    "next": "AccountProfileUidRead"
                },
                "AccountProfileUidRead": {
                    "next": "AccountProfilePrestigeStart",
                    "on_error": "AccountProfilePrestigeStart"
                },
                "AccountProfilePrestigeStart": {
                    "recognition": {
                        "type": "TemplateMatch",
                        "param": {
                            "template": "main_map.png",
                            "threshold": 0.95
                        }
                    }
                },
                "AccountProfilePrestigeDone": {
                    "next": "AccountProfileCityUnlockStart"
                },
                "AccountProfileCityUnlockDone": {
                    "next": "AccountProfileRoleResonanceStart"
                },
                "AccountProfileRoleResonanceStart": {
                    "recognition": "TemplateMatch",
                    "template": "main_map.png",
                    "threshold": 0.95
                },
                "AccountProfileRoleResonanceDone": {
                    "next": "ManualTwoCityBusinessAccountProfileWarmupDone"
                },
                "ManualTwoCityBusinessSetMedicineLimits": {
                    "next": "AutoTwoCityBusinessCalculate"
                }
            },
            "option": [
                "AutoTwoCityPriorityCity1",
                "AutoTwoCityPriorityCity2",
                "AutoTwoCityExcludeCities",
                "AutoTwoCityPlannerParams",
                "AutoTwoCityWulinyuanPriority",
                "ManualTwoCityRunMode",
                "ManualTwoCityAccountProfileReadMode",
                "ManualTwoCityAutoImpactDrill",
                "ManualTwoCityAutoSpeedProjectile",
                "ManualTwoCityAutoDrink",
                "ManualTwoCityAutoBento",
                "ManualTwoCityUseMedicine"
            ]
        }
    ],
